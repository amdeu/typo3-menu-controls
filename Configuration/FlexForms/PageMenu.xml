<T3DataStructure>
    <sheets>
        <selection>
            <ROOT>
                <sheetTitle>Record selection</sheetTitle>
                <type>array</type>
                <el>
                    <settings.demand.parents>
                        <label>Parents</label>
                        <config>
                            <type>group</type>
                            <internal_type>db</internal_type>
                            <allowed>pages</allowed>
                            <size>3</size>
                            <maxitems>50</maxitems>
                            <minitems>0</minitems>
                        </config>
                    </settings.demand.parents>
                    <settings.demand.records>
                        <label>Records</label>
                        <config>
                            <type>group</type>
                            <internal_type>db</internal_type>
                            <allowed>pages</allowed>
                            <size>10</size>
                            <maxitems>100</maxitems>
                            <minitems>0</minitems>
                        </config>
                    </settings.demand.records>
                </el>
            </ROOT>
        </selection>
        <demand>
            <ROOT>
                <sheetTitle>Selection settings</sheetTitle>
                <type>array</type>
                <el>
                    <settings.demand.additionalSettings.types>
                        <label>Allowed types</label>
                        <config>
                            <type>select</type>
                            <renderType>selectCheckBox</renderType>
                            <itemsProcFunc>UBOS\Puck\UserFunc\FormEngine\ContentItemsProcFunc->doktypes
                            </itemsProcFunc>
                            <items>
                                <numIndex index="0">
                                    <label>0</label>
                                    <value>0</value>
                                </numIndex>
                            </items>
                            <default>1,4,3</default>
                        </config>
                    </settings.demand.additionalSettings.types>
                    <settings.demand.additionalSettings.navHide>
                        <label>Respect hidden in menus</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                            <default>1</default>
                        </config>
                    </settings.demand.additionalSettings.navHide>
                    <settings.demand.limit>
                        <label>Maximum number of records displayed</label>
                        <config>
                            <type>input</type>
                            <eval>num</eval>
                            <size>2</size>
                        </config>
                    </settings.demand.limit>
                    <settings.demand.offset>
                        <label>Number of records to skip before displaying the first record</label>
                        <config>
                            <type>input</type>
                            <eval>num</eval>
                            <size>2</size>
                        </config>
                    </settings.demand.offset>
                    <settings.demand.categoryGroups.main.uids>
                        <label>Categories</label>
                        <config>
                            <type>category</type>
                            <size>12</size>
                            <minitems>0</minitems>
                            <maxitems>99</maxitems>
                        </config>
                    </settings.demand.categoryGroups.main.uids>
                    <settings.demand.categoryGroups.main.conjunction>
                        <label>Category conjunction</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="1">
                                    <numIndex index="0">OR</numIndex>
                                    <numIndex index="1">or</numIndex>
                                </numIndex>
                                <numIndex index="2">
                                    <numIndex index="0">AND</numIndex>
                                    <numIndex index="1">and</numIndex>
                                </numIndex>
                                <numIndex index="3">
                                    <numIndex index="0">Not OR</numIndex>
                                    <numIndex index="1">notor</numIndex>
                                </numIndex>
                                <numIndex index="4">
                                    <numIndex index="0">Not AND</numIndex>
                                    <numIndex index="1">notand</numIndex>
                                </numIndex>
                            </items>
                        </config>
                    </settings.demand.categoryGroups.main.conjunction>
                </el>
            </ROOT>
        </demand>
        <order>
            <ROOT>
                <sheetTitle>Order</sheetTitle>
                <type>array</type>
                <el>
                    <settings.demand.orderField>
                        <label>Order by</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <numIndex index="0">List sorting</numIndex>
                                    <numIndex index="1">sorting</numIndex>
                                </numIndex>
                                <numIndex index="1">
                                    <numIndex index="0">Last updated</numIndex>
                                    <numIndex index="1">lastUpdated</numIndex>
                                </numIndex>
                                <numIndex index="3">
                                    <numIndex index="0">Title</numIndex>
                                    <numIndex index="1">title</numIndex>
                                </numIndex>
                            </items>
                        </config>
                    </settings.demand.orderField>
                    <settings.demand.orderDirection>
                        <label>Order direction</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <numIndex index="0">Ascending</numIndex>
                                    <numIndex index="1">asc</numIndex>
                                </numIndex>
                                <numIndex index="1">
                                    <numIndex index="0">Descending</numIndex>
                                    <numIndex index="1">desc</numIndex>
                                </numIndex>
                            </items>
                        </config>
                    </settings.demand.orderDirection>
                    <settings.demand.orderByRecordsProperty>
                        <label>Order by record selection</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                        </config>
                    </settings.demand.orderByRecordsProperty>
                </el>
            </ROOT>
        </order>
        <pagination>
            <ROOT>
                <sheetTitle>Pagination</sheetTitle>
                <type>array</type>
                <el>
                    <settings.pagination.enabled>
                        <label>Pagination</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                            <default>0</default>
                        </config>
                    </settings.pagination.enabled>
                    <settings.pagination.itemsPerPage>
                        <label>Items per page</label>
                        <config>
                            <required>1</required>
                            <type>input</type>
                            <eval>num</eval>
                            <size>2</size>
                            <default>12</default>
                        </config>
                    </settings.pagination.itemsPerPage>
                </el>
            </ROOT>
        </pagination>
        <filter>
            <ROOT>
                <sheetTitle>Filter</sheetTitle>
                <type>array</type>
                <el>
                    <settings.categoryFilter.enabled>
                        <label>Show category filter</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                            <default>0</default>
                        </config>
                    </settings.categoryFilter.enabled>
                    <settings.categoryFilter.categories>
                        <label>Filter categories</label>
                        <config>
                            <type>category</type>
                            <size>12</size>
                            <minitems>0</minitems>
                            <maxitems>100</maxitems>
                        </config>
                    </settings.categoryFilter.categories>
                    <settings.categoryFilter.treeCategories>
                        <label>Filter parent categories</label>
                        <description>Creates filter categories from children of selected categories.</description>
                        <config>
                            <type>category</type>
                            <size>12</size>
                            <minitems>0</minitems>
                            <maxitems>100</maxitems>
                        </config>
                    </settings.categoryFilter.treeCategories>
                    <settings.categoryFilter.multiSelect>
                        <label>Enable multi-select</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                            <default>1</default>
                        </config>
                        <onChange>reload</onChange>
                    </settings.categoryFilter.multiSelect>
                    <settings.categoryFilter.checkPotential>
                        <label>Disable buttons without potential results</label>
                        <config>
                            <type>check</type>
                            <renderType>checkboxToggle</renderType>
                            <default>0</default>
                        </config>
                    </settings.categoryFilter.checkPotential>
                </el>
            </ROOT>
        </filter>

    </sheets>
</T3DataStructure>